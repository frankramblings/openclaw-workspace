# OpenClaw Workspace — configuration knobs (all optional).
#
# Nothing here is required for a basic run: the workspace reads the gateway
# password and default model straight from ~/.openclaw/openclaw.json, and the
# agent name from .data/branding.json (written by scripts/setup.sh). Set a value
# here only to override a default. To actually load this file, either export the
# vars in your shell, or reference them from your process manager (the macOS
# LaunchAgent has an EnvironmentVariables block; see deploy/).

# ── Branding ────────────────────────────────────────────────────────────────
# Usually set via `scripts/setup.sh` (persisted to .data/branding.json). Env
# wins over the file if you'd rather pin it here.
#WORKSPACE_AGENT_NAME=Gary
#WORKSPACE_ACCENT=#4fe3d1

# ── OpenClaw gateway (the brain) ────────────────────────────────────────────
# By default the gateway URL/port/password come from ~/.openclaw/openclaw.json.
#OPENCLAW_HOME=~/.openclaw
#OPENCLAW_GATEWAY_WS=ws://127.0.0.1:18789
#OPENCLAW_GATEWAY_PORT=18789
#OPENCLAW_GATEWAY_PASSWORD=                 # else read from openclaw.json
#OPENCLAW_DEFAULT_MODEL=openai/gpt-5.5      # else agents.list[0].model

# Session keys: the web UI gets its own thread so it never contends with Signal.
#OPENCLAW_SESSION_KEY=agent:main:main
#OPENCLAW_WEB_SESSION_KEY=agent:main:web
#OPENCLAW_WEB_SESSION_PREFIX=agent:main:web

# ── Timeouts / paths ────────────────────────────────────────────────────────
#WORKSPACE_TURN_TIMEOUT_S=180
#WORKSPACE_RESEARCH_TURN_TIMEOUT_S=600
#WORKSPACE_DATA_DIR=./.data
#WORKSPACE_FRONTEND_DIR=./frontend
#WORKSPACE_EMOJI_CACHE=./.data/emoji-cache

# ── Inbox collectors (only if you use the Inbox tab) ────────────────────────
# Which collectors run is config-driven via an optional .data/inbox.json
# (gitignored; default = ALL collectors on). See the README "Inbox" section for
# the schema. The env vars below OVERRIDE the matching inbox.json values, and
# the *_ENABLED toggles override the per-collector "enabled" flag.
#INBOX_GMAIL_ENABLED=true
#INBOX_SLACK_ENABLED=true
#INBOX_ASANA_ENABLED=true
#INBOX_OBSIDIAN_ENABLED=true
#INBOX_DOCUMENTS_ENABLED=true
# Which addresses count as "internal" / your Slack workspace, etc.
#INBOX_INTERNAL_DOMAIN=example.com
#SLACK_DOMAIN=example.slack.com
#INBOX_GMAIL_LIST=INBOX
#INBOX_MEETINGS_DIR=~/.openclaw/workspace/Meetings
#OBSIDIAN_WINDOW_DAYS=2
#SLACK_STALE_MIN=30
#ASANA_PROJECT_GID=                         # your Asana project GID (empty = Asana off)
#INBOX_ASANA_ENV=~/.openclaw/workspace/secrets/asana.env   # file holding ASANA_PAT=...
#SERPAPI_API_KEY=                           # else read from openclaw.json serpapi skill

# ── Email / Calendar (only if you wire those tabs) ──────────────────────────
# Email is configured via `scripts/setup.sh --add-email` (writes a himalaya
# config.toml account + a mode-600 secret file). HIMALAYA_CONFIG overrides the
# config path (used by tests). WORKSPACE_EMAIL_ADDRESS overrides the From address.
#WORKSPACE_EMAIL_ADDRESS=you@example.com
#HIMALAYA_BIN=/usr/local/bin/himalaya
#HIMALAYA_CONFIG=~/.config/himalaya/config.toml
#GOOGLE_CAL_TOKENS=~/.config/google-calendar-mcp/tokens.json
#GOOGLE_OAUTH_KEYS=~/.gmail-mcp/gcp-oauth.keys.json

# ── Documents ───────────────────────────────────────────────────────────────
#DOCS_STALE_DAYS=4
