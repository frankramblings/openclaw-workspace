# Python
__pycache__/
*.py[cod]
.venv
.venv/
venv/
*.egg-info/

# Env / secrets
.env
*.local

# frontend/ is the BUILD OUTPUT: scripts/sync-frontend.sh assembles it from the
# vendored neutral base (frontend-vendor/, committed) + frontend-overrides/, and
# bakes in the agent name. It's a generated artifact, so it's gitignored.
/frontend/

# Node (icon generator deps)
node_modules/

# OS
.DS_Store
._*
.AppleDouble
.Spotlight-V100
.Trashes

# Editor
.vscode/
.idea/

# Local session metadata store
/.data/

# Git worktrees for isolated feature work
/.worktrees/
.superpowers/
/tmp/
OVERNIGHT-REPORT.md

.claude/settings.local.json

# Transient CSS editing-session backups
frontend-overrides/.redesign.css.*

# Personal native iOS shell (carries private tailnet host; not for public repo)
/native/

# Internal planning / handoff material (superpowers plans, specs, handoffs).
# Not user docs, and it carries private tailnet hostnames/IPs + /home paths, so
# it's excluded from the publish-bound repo. Already-tracked files must also be
# untracked once: `git rm -r --cached docs/superpowers/`.
/docs/superpowers/

# Runtime branch-context handoff payloads (per-branch pending-context store).
# .gitkeep keeps the directory itself tracked; the generated JSON files are
# process-local runtime state, not source.
/data/branch_context/*
!/data/branch_context/.gitkeep
